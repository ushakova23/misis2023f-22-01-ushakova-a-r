#include <iostream>
#include <algorithm>

int main() {
    int x1, x2, x3;
    std::cin >> x1 >> x2 >> x3;

    int coordinates[] = { x1, x2, x3 };
    std::sort(coordinates, coordinates + 3);

    int minDistance = coordinates[2] - coordinates[0];

    std::cout << minDistance << std::endl;

    return 0;
}
